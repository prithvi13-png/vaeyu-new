# Web3Forms access key — get yours free at web3forms.com (enter your email, they send the key)
# 250 free submissions/month, no credit card needed
VITE_WEB3FORMS_KEY=

# Google Analytics — paste your GA4 Measurement ID (G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# Calendly inline embed URL — paste your Calendly booking page URL
# Example: https://calendly.com/your-username/30min
# If blank, the "Book a Call" tab shows an email fallback
VITE_CALENDLY_URL=
